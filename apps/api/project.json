{
  "name": "@org/api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "command": "node --import tsx/esm src/index.ts",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "command": "tsc -p tsconfig.json",
      "options": {
        "cwd": "{projectRoot}"
      }
    }
  }
}
